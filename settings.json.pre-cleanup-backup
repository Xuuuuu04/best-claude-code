{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Edit(**/.claude/artifacts/**)",
      "Write(**/.claude/artifacts/**)",
      "Edit(**/.claude/agent-memory/**)",
      "Write(**/.claude/agent-memory/**)",
      "Edit(**/.claude/logs/**)",
      "Write(**/.claude/logs/**)",
      "Edit(**/.claude/instructions-log.txt)",
      "Write(**/.claude/instructions-log.txt)",
      "Edit(**/.claude/cost-log.txt)",
      "Write(**/.claude/cost-log.txt)",
      "Edit(**/.claude/hook-errors.log)",
      "Write(**/.claude/hook-errors.log)",
      "Edit(**/.claude/state/**)",
      "Write(**/.claude/state/**)",
      "Edit(**/.claude/tmp/**)",
      "Write(**/.claude/tmp/**)",
      "Bash(mkdir -p .claude/*)",
      "Bash(mkdir -p .claude/**/*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/session-start.sh",
            "statusMessage": "Loading context..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/pre-compact.sh",
            "statusMessage": "Saving working state...",
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/post-compact.sh",
            "statusMessage": "Restoring dispatcher context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/orchestrator-edit-guard.sh"
          },
          {
            "type": "command",
            "command": "echo 'Migration files are read-only. Create a new migration via prisma CLI instead.' >&2 && exit 2",
            "if": "Edit(**/prisma/migrations/**)|Write(**/prisma/migrations/**)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/post-edit-lint.sh",
            "timeout": 30,
            "statusMessage": "Running linter...",
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/artifact-index-suggest.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/subagent-start-mark.sh",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/subagent-stop-log.sh",
            "async": true
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/instructions-audit.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/clarification-gate.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/review-gate.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$AI_TERMINAL_SESSION_ID\" ] && printf '' > /tmp/aitm-stop-\"$AI_TERMINAL_SESSION_ID\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/session-stop-remind.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/stop-quality-gate.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/permissionrequest-exit-plan-allow.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/_lib/run-with-logging.sh $HOME/.claude/hooks/tool-failure-audit.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "playwright@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "outputStyle": "legion-dispatch",
  "language": "Chinese",
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "teammateMode": "tmux",
  "_plugins_note": "LSP plugins should be installed per-project as needed via the project-level plugins array. Remove them from here to avoid global overhead.",
  "_permission_note": "默认采用保守权限。subagent 继续复用 settings 中声明的共享 MCP，不为权限收紧重复下沉 mcpServers。",
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PAT}"
      }
    }
  },
